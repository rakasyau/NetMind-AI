# =========================================================================
# NetMind AI - Production Environment Configurations (.env.example)
# =========================================================================

# ----------------- HOSTING & ENVIRONMENT -----------------
# [DEFAULT] Production Node environment
NODE_ENV=production

# [DEFAULT] The port the Express server listens to (hardcoded to 3000 in server.ts)
PORT=3000

# [REQUIRED] The public domain name where the application is hosted.
# Used for securing API headers, CORS verification, and webhooks.
APP_URL=https://netmind-ai.rakasyau.my.id

# ----------------- GEMINI API PROVIDER -----------------
# [REQUIRED - MANUAL] Your Google Gemini API Key.
# Obtain a key for free or pay-as-you-go from Google AI Studio:
# https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ----------------- DATABASE (MONGODB ATLAS) -----------------
# [REQUIRED - MANUAL] MongoDB Atlas Connection URI
#
# Format for MongoDB Atlas:
# mongodb+srv://<username>:<password>@<cluster-address>/netmind_db?retryWrites=true&w=majority
#
# Recommended Production URL Query Parameters:
# - retryWrites=true: Automatically retries write operations on transient network failure.
# - w=majority: Wait for write acknowledgement from a majority of replica set members.
# - connectTimeoutMS=10000: Initial connection timeout in milliseconds (10s).
# - socketTimeoutMS=45000: Socket timeout for operations (45s).
#
# Replace `<username>`, `<password>`, and `<cluster-address>` with your Atlas credentials.
# Ensure you URL-encode the password if it contains special characters (e.g., @, :, /, +).
MONGODB_URI=mongodb+srv://netmind_user:secure_password@cluster0.abcde.mongodb.net/netmind_db?retryWrites=true&w=majority&connectTimeoutMS=10000&socketTimeoutMS=45000
